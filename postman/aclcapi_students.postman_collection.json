{
  "info": {
    "name": "ACLCAPI Students",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Students",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students.php?fields=basic",
          "host": ["{{baseUrl}}"],
          "path": ["students.php"],
          "query": [
            {
              "key": "fields",
              "value": "basic"
            }
          ]
        }
      }
    },
    {
      "name": "Get Student By student_id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students.php?student_id=22000080800&fields=basic",
          "host": ["{{baseUrl}}"],
          "path": ["students.php"],
          "query": [
            {
              "key": "student_id",
              "value": "22000080800"
            },
            {
              "key": "fields",
              "value": "basic"
            }
          ]
        }
      }
    },
    {
      "name": "Get Student By id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students.php?id=12&fields=basic",
          "host": ["{{baseUrl}}"],
          "path": ["students.php"],
          "query": [
            {
              "key": "id",
              "value": "12"
            },
            {
              "key": "fields",
              "value": "basic"
            }
          ]
        }
      }
    },
    {
      "name": "Create Student",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"StudentID\": \"22000080800\",\n  \"Name\": \"Juan Dela Cruz\",\n  \"Program\": \"BSIS\",\n  \"YearLevel\": \"2\",\n  \"Gmail\": \"juan.delacruz@gmail.com\"\n}"
        },
        "description": "Student payload is intentionally limited to StudentID, Name, Program, YearLevel, and Gmail.",
        "url": {
          "raw": "{{baseUrl}}/students.php",
          "host": ["{{baseUrl}}"],
          "path": ["students.php"]
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const body = JSON.parse(pm.request.body.raw);",
                "const allowed = ['StudentID', 'Name', 'Program', 'YearLevel', 'Gmail'];",
                "const keys = Object.keys(body);",
                "pm.test('Student payload only includes the allowed fields', function () {",
                "  pm.expect(keys.sort()).to.eql(allowed.sort());",
                "});"
              ]
            }
          }
        ]
      }
    },
    {
      "name": "Update Student",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"StudentID\": \"22000080800\",\n  \"Name\": \"Juan Dela Cruz Jr.\",\n  \"Program\": \"BSIS\",\n  \"YearLevel\": \"3\",\n  \"Gmail\": \"juan.delacruz@gmail.com\"\n}"
        },
        "description": "Student payload is intentionally limited to StudentID, Name, Program, YearLevel, and Gmail.",
        "url": {
          "raw": "{{baseUrl}}/students.php",
          "host": ["{{baseUrl}}"],
          "path": ["students.php"]
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const body = JSON.parse(pm.request.body.raw);",
                "const allowed = ['StudentID', 'Name', 'Program', 'YearLevel', 'Gmail'];",
                "const keys = Object.keys(body);",
                "pm.test('Student payload only includes the allowed fields', function () {",
                "  pm.expect(keys.sort()).to.eql(allowed.sort());",
                "});"
              ]
            }
          }
        ]
      }
    },
    {
      "name": "Delete Student By student_id",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students.php?student_id=22000080800",
          "host": ["{{baseUrl}}"],
          "path": ["students.php"],
          "query": [
            {
              "key": "student_id",
              "value": "22000080800"
            }
          ]
        }
      }
    },
    {
      "name": "Delete Student By id",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students.php?id=12",
          "host": ["{{baseUrl}}"],
          "path": ["students.php"],
          "query": [
            {
              "key": "id",
              "value": "12"
            }
          ]
        }
      }
    }
  ]
}
